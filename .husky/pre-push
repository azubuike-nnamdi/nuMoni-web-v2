#!/bin/sh

echo "🔍 Running pre-push hook..."

files_changed=$(git diff --name-only origin/main...HEAD 2>/dev/null)

# Install dependencies if package.json changed
if echo "$files_changed" | grep -q "package.json"; then
  echo "📦 Dependencies changed. Running pnpm install..."
  pnpm install || exit 1
fi

# Run knip to detect unused files and exports
echo "🕵️ Running knip check..."
pnpm knip || exit 1

# Run lint
echo "🧹 Running lint..."
pnpm run lint || exit 1

# Run type check
echo "🔎 Running type check..."
pnpm run type-check || exit 1

# Run build
echo "🏗️ Running build..."
pnpm run build || exit 1

echo "✅ All checks passed. Proceeding with push."
exit 0